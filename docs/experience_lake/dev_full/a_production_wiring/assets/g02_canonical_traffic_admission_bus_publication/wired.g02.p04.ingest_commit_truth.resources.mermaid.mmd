    LG3["This graph stays on current wired ingest evidence closure and names the pinned artifact set"]
  end

  ENTRY["Run-scoped ingress activity<br>or explicit empty-run waiver"]

  subgraph BASIS["Ingress evidence basis resources"]
    IGDDB[("DynamoDB table<br>fraud-platform-dev-full-ig-idempotency")]
    IGRECEIPTS["IG receipts / quarantine refs"]
    RUNCTL["Run control<br>conformance / receipts"]
    MODE["Pinned proof mode<br>admission-index proxy for current ingress edge"]
  end

  subgraph EVIDENCE["Committed ingest evidence resources"]
    EVID[("S3 bucket<br>fraud-platform-dev-full-evidence")]
