    TRTDL[("Topic<br>fp.bus.rtdl.v1")]
    TAUDIT[("Topic<br>fp.bus.audit.v1")]
    MSF["Managed Flink app<br>fraud-platform-dev-full-rtdl-ieg-ofp-v0<br>retained parity only"]
