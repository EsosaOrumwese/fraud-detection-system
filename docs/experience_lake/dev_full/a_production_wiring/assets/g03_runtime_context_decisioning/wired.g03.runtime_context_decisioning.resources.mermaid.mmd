    TFLOW[("Topic<br>fp.bus.context.flow_anchor.fraud.v1")]
    ALLOWED[("Runtime-allowed oracle set<br>s3_event_stream_with_fraud_6B<br>arrival_events_5B<br>s1_arrival_entities_6B<br>s3_flow_anchor_with_fraud_6B")]
    REGACTIVE[("Active bundle / policy resolution<br>runtime-consumed registry truth")]
  end

  subgraph RTDL["Concrete RTDL runtime seats"]
    EKS["EKS cluster<br>fraud-platform-dev-full"]
    NSRTDL["Namespace<br>fraud-platform-rtdl"]
    SARTDL["ServiceAccount<br>rtdl"]
    SADEC["ServiceAccount<br>decision-lane"]
    CSFB["Deployment<br>fp-pr3-csfb"]
    IEG["Deployment<br>fp-pr3-ieg"]
    OFP["Deployment<br>fp-pr3-ofp"]
    DL["Deployment<br>fp-pr3-dl"]
    DF["Deployment<br>fp-pr3-df"]
    AL["Deployment<br>fp-pr3-al"]
