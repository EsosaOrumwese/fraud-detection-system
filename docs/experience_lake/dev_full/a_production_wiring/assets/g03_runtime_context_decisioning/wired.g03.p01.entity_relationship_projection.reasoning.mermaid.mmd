    E4["Only the live-runtime-allowed oracle surfaces are permitted in runtime"]
    E5["Truth-only outputs and future-implying fields are forbidden from live use"]
    E6["The handles registry pins exactly four live-runtime-allowed oracle outputs for runtime: s3_event_stream_with_fraud_6B, arrival_events_5B, s1_arrival_entities_6B, s3_flow_anchor_with_fraud_6B"]
  end

  subgraph SPINE["5. Broad route logic"]
    R1["Admitted traffic and context topics"]
