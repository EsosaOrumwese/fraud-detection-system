%% Simplified baseline resource view with shared resource bundles and path labels on the flows
flowchart LR

  subgraph LEGEND["How to Read This Graph"]
    L1["Nodes are bundled resource surfaces, not individual resources"]
    L2["Edges are labeled by the path families that use those same resource bundles"]
    L3["Path labels are expanded: Admission, Hot/Decision, Case+Label, Learning, Recovery, Degrade, Replay, Rollback, Observability, Cost Control"]
  end

  OBJ[("S3 object store<br>oracle / archive basis")]
  CTRL["Control resources<br>GitHub Actions / Terraform / Step Functions / ECR"]
  WSPR["Replay resources<br>ECS/Fargate WSP"]
  INGR["Ingress resources<br>API Gateway / ALB / Lambda / ECS<br>DynamoDB / SQS"]
  TRAN[("Transport resources<br>MSK Serverless / Glue Registry")]
  RTDLR["RTDL resources<br>EKS namespace + RTDL deployments"]
  CASER["Case + Label resources<br>EKS namespace + CaseTrigger / CM / LS"]
  LEARNR["Learning resources<br>Databricks / Glue DB / SageMaker / MLflow"]
  REGR[("Registry / active bundle truth")]
  GOVR[("Evidence resources<br>S3 evidence / archive / run-control receipts")]
  OBSR["Observability resources<br>CloudWatch / operations dashboard"]
  COSTR["Cost resources<br>budget / cost dashboard / idle-safe receipts"]
  SHARED["Shared substrate<br>VPC / endpoints / IAM / IRSA / SSM / Aurora / tfstate"]

  SHARED -->|substrate| CTRL
