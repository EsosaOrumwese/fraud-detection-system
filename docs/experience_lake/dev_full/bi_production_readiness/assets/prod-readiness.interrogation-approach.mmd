flowchart TD

    META["Meta goal (implicit)<br/>A serious reviewer infers senior-level ML Platform and MLOps capability"]:::meta
    AGOAL["A achieved enough<br/>Current wired platform is real, bounded, and understood"]:::finish
    BGOAL["Bi goal (implicit)<br/>Expose the A-mapped wired platform to production-shaped pressure,<br/>reveal wired-to-ready gaps, justify the bridges,<br/>and make readiness boundaries solid enough for promotion"]:::goal

    META --> AGOAL --> BGOAL

    BSTART["Start Bi interrogation<br/>Use A as the map,<br/>not as something to rediscover"]:::step
    BGOAL --> BSTART

    BBOUND["Pin the Bi boundary<br/>Bi asks readiness questions only:<br/>what breaks under production-shaped pressure,<br/>why it breaks, what gap that reveals,<br/>and what justifiably bridges it"]:::boundary
    BSTART --> BBOUND

    BFREEZE["Freeze Bi-core evidence surfaces"]:::step
    BBOUND --> BFREEZE

    subgraph BEVID["Bi-core evidence surfaces"]
        direction TB
        BV1["A map<br/>groups, paths, owned outcomes, syntheses"]:::surface
        BV2["Readiness implementation note<br/>primary reasoning authority for what actually happened"]:::surface
        BV3["Readiness plan + active phase authority<br/>goal, target, closure rule"]:::surface
        BV4["Accepted green chain<br/>what this proof is allowed to inherit"]:::surface
        BV5["Bi gap register<br/>boundary, pressure, target, observed,<br/>gap class, chosen bridge, bridge effect,<br/>promotion scope, what remains open"]:::register
    end

    BFREEZE --> BV1
    BFREEZE --> BV2
    BFREEZE --> BV3
    BFREEZE --> BV4
    BFREEZE --> BV5

    BSELECT["Select the active A-defined object under pressure<br/>one group, one path, one plane,<br/>or one coupled boundary"]:::step
    BV1 --> BSELECT

    subgraph BFRAME["Bi gap frame"]
        direction TB
        BCURR["State current wired truth<br/>What is true now about this boundary?"]:::step
        BREADY["State production-ready truth<br/>What would have to be true for this boundary to count as ready?"]:::step
        BQUESTION["State exact readiness question<br/>What exact wired-to-ready gap is being tested?"]:::step
        BCURR --> BREADY --> BQUESTION
    end

    BSELECT --> BCURR

    subgraph BPFAM["Production-pressure families"]
        direction TB
        PF1["Envelope pressure<br/>steady, burst, recovery, latency, lag"]:::pressure
        PF2["Semantic pressure<br/>no future leakage, no false-ready,<br/>no shadow truth, no false-green"]:::pressure
        PF3["Coupling pressure<br/>newly attached boundary stays truthful<br/>inside enlarged network"]:::pressure
        PF4["Authority pressure<br/>right source of truth, right active bundle,<br/>right rollup authority"]:::pressure
        PF5["Observability pressure<br/>fresh telemetry, drift visibility,<br/>active-path fidelity"]:::pressure
        PF6["Cost pressure<br/>bounded spend, no proof by waste"]:::pressure
    end

    BPRESS["Select the relevant production pressure"]:::step
    BQUESTION --> BPRESS
    BPRESS --> PF1
    BPRESS --> PF2
    BPRESS --> PF3
    BPRESS --> PF4
    BPRESS --> PF5
    BPRESS --> PF6

    BTARGET["Pin target vs observed frame<br/>target, tolerance, fail-fast red,<br/>and what would count as a truthful verdict"]:::step
    PF1 --> BTARGET
    PF2 --> BTARGET
    PF3 --> BTARGET
    PF4 --> BTARGET
    PF5 --> BTARGET
    PF6 --> BTARGET

    BTELE["Pin telemetry before spend<br/>live logs, live counters, boundary health,<br/>fail-fast triggers, minimal hardening artifacts"]:::step
    BTARGET --> BTELE

    BPROOF{"Truthful proof shape ready?"}:::decision
    BTELE --> BPROOF

    BBLIND["Fix proof-shape / attribution / observability blindspot first<br/>Do not spend yet"]:::step
    BPROOF -- "No" --> BBLIND
    BBLIND --> BTELE

    BRUN["Apply the smallest truthful production-shaped run<br/>Keep AWS-real and preserve production shape"]:::step
    BPROOF -- "Yes" --> BRUN

    BOBS["Measure target vs observed<br/>What held? What broke?<br/>What stayed green only advisory?"]:::step
    BRUN --> BOBS

    BGAP["Reveal the gap<br/>target, observed, delta,<br/>missing readiness property,<br/>impact on boundary / group / enlarged network"]:::step
    BOBS --> BGAP

    BCLASS0{"What kind of gap is this?"}:::decision
    BGAP --> BCLASS0

    ADEFECT["A correction<br/>pressure exposed that the wired foundation itself<br/>is still wrong or incomplete"]:::gap
    PDEFECT["Proof-boundary defect<br/>methodology, proof shape, rollup authority,<br/>telemetry / observability defect"]:::gap
    BIDEFECT["True Bi readiness insufficiency<br/>runtime, semantic, coupling, capacity,<br/>authority, or cost defect"]:::gap

    BCLASS0 --> ADEFECT
    BCLASS0 --> PDEFECT
    BCLASS0 --> BIDEFECT

    AFIX["Return to A-boundary correction<br/>Fix the wired object before claiming readiness work"]:::bridge
    ADEFECT --> AFIX
    AFIX --> BCURR

    BCAND["State candidate bridges<br/>What could close this gap<br/>without weakening production shape?"]:::bridge
    PDEFECT --> BCAND
    BIDEFECT --> BCAND

    BJUST["Choose and justify the bridge<br/>Why this is the least-distorting move<br/>from current wired truth toward ready truth"]:::bridge
    BCAND --> BJUST

    BEFFECT["State the bridge effect explicitly<br/>What readiness property did this bridge improve?<br/>What evidence would show the bridge,<br/>not just the rerun, closed the gap?"]:::bridge
    BJUST --> BEFFECT

    BREC["Write one Bi boundary output<br/>current truth<br/>ready truth<br/>pressure family<br/>target vs observed<br/>gap class<br/>chosen bridge<br/>bridge effect<br/>what remains open"]:::step
    BEFFECT --> BREC
    BREC --> BV5

    BRERUN["Rerun the same truthful boundary<br/>Do not invent a new easy question"]:::step
    BREC --> BRERUN
    BRERUN --> BOBS

    BSOLID{"Boundary now solid enough?"}:::decision
    BOBS --> BSOLID

    BSOLIDNOTE["State solidity verdict<br/>what is now solid,<br/>why it is solid,<br/>and what remains open"]:::groupconclusion
    BSOLID -- "Yes" --> BSOLIDNOTE
    BSOLID -- "No" --> BCLASS0

    BSCOPE["State promotion scope explicitly<br/>boundary only?<br/>group?<br/>plane?<br/>enlarged working network?"]:::step
    BSOLIDNOTE --> BSCOPE

    BPROM{"Promotion justified for that scope?"}:::decision
    BSCOPE --> BPROM

    BUP["Promote into the accepted green chain<br/>only after explainable proof"]:::step
    BPROM -- "Yes" --> BUP
    BPROM -- "No" --> BPRESS

    BNEXT{"More A-defined readiness boundaries to interrogate?"}:::decision
    BUP --> BNEXT
    BNEXT -- "Yes" --> BSELECT
    BNEXT -- "No" --> BSYN

    BSYN["Bi synthesis<br/>Show which A-defined boundaries were pressured,<br/>what gaps were revealed,<br/>how bridges were justified,<br/>what is now solid,<br/>what was promoted,<br/>and what remains open"]:::goal
    BSYN --> BFINAL

    BFINAL["Final Bi-supporting claims<br/>The wired platform has been truthfully pressured;<br/>wired-to-ready gaps are explicit;<br/>bridges are justified;<br/>promotion scope is explicit;<br/>and remaining open readiness boundaries are visible"]:::claims
    BFINAL --> META

    classDef meta fill:#f8d7da,stroke:#b42318,color:#111;
    classDef goal fill:#d1fadf,stroke:#027a48,color:#111;
    classDef step fill:#dbeafe,stroke:#1d4ed8,color:#111;
    classDef boundary fill:#fee2e2,stroke:#b91c1c,color:#111;
    classDef surface fill:#ecfccb,stroke:#4d7c0f,color:#111;
    classDef register fill:#fef3c7,stroke:#b45309,color:#111;
    classDef decision fill:#ede9fe,stroke:#6d28d9,color:#111;
    classDef pressure fill:#fae8ff,stroke:#a21caf,color:#111;
    classDef gap fill:#fee2e2,stroke:#c2410c,color:#111;
    classDef bridge fill:#cffafe,stroke:#0f766e,color:#111;
    classDef groupconclusion fill:#ffe4e6,stroke:#be123c,color:#111;
    classDef claims fill:#e0f2fe,stroke:#0369a1,color:#111;
    classDef finish fill:#f3f4f6,stroke:#374151,color:#111;