---
config:
  layout: dagre
  theme: default
---
flowchart LR

  subgraph LEGEND["How to Read This Graph"]
    LG1["Square node = managed learning / MLOps surface"]
    LG2[("Round store = persistent dataset, evidence, or registry state")]
    LG3["Dashed edge = pinned serving handle or lineage-only relationship"]
  end

  subgraph LEARN["dev_full Learning / MLOps Graph"]
    ORACLE["Oracle store inputs<br>read-only runtime boundary"]
    OBJ[("S3 object store<br>datasets / manifests / evidence refs")]
    TLABELS[["fp.bus.labels.events.v1"]]
    TOFSREQ[["fp.bus.learning.ofs.requests.v1"]]
    TOFSEVT[["fp.bus.learning.ofs.events.v1"]]
    TMFREQ[["fp.bus.learning.mf.requests.v1"]]
    TMFEVT[["fp.bus.learning.mf.events.v1"]]
    TREG[["fp.bus.learning.registry.events.v1"]]

    DBX["Databricks (OFS)<br>dataset build / replay materialization"]
    DBXBUILD["OFS build job<br>fraud-platform-dev-full-ofs-build-v0"]
    DBXQUAL["OFS quality job<br>fraud-platform-dev-full-ofs-quality-v0"]
    GLUEDB[("Glue DBs<br>fraud_platform_dev_full_ofs<br>fraud_platform_dev_full_m15")]

    SM["SageMaker (MF)<br>train / eval / candidate bundle creation"]
    MLFLOW["MLflow (MPR)<br>Databricks-managed tracking<br>promotion / rollback / active resolution"]
    SMPKG["Model package group<br>fraud-platform-dev-full-models"]
    SMENDPT["Pinned serving handle<br>fraud-platform-dev-full-online-v0"]

    REGACTIVE["Active bundle / policy truth"]
    DF["Runtime consumer<br>Decision Fabric"]

    EVID[("S3 evidence bucket")]
    PROMO["Promotion receipts"]
    ROLLBACK["Rollback drill receipts"]
    SSM["SSM handles<br>Databricks / MLflow / SageMaker refs"]
    ROLEDBX["Databricks cross-account role"]
    ROLESM["SageMaker execution role"]
  end

  ORACLE -->|stored inside| OBJ
  TLABELS -->|consumed by| DBX
  OBJ -->|replayed by| DBX
  TOFSREQ -->|consumed by| DBX
  DBX -->|runs| DBXBUILD
  DBX -->|runs| DBXQUAL
  DBXBUILD -->|writes dataset tables to| GLUEDB
  DBXBUILD -->|writes manifests to| OBJ
  DBXQUAL -->|stores quality receipts in| EVID
  DBX -->|publishes OFS completion to| TOFSEVT
  TOFSEVT -->|consumed by| SM
  TMFREQ -->|consumed by| SM
  SM -->|writes train/eval lineage to| MLFLOW
  SM -->|publishes MF events to| TMFEVT
  SM -->|publishes model packages to| SMPKG
  SMPKG -. bundle lineage .-> MLFLOW
  TMFEVT -->|captured by| MLFLOW
  MLFLOW -->|publishes registry events to| TREG
  MLFLOW -->|writes promotion receipts to| PROMO
  MLFLOW -->|writes rollback receipts to| ROLLBACK
  MLFLOW -->|resolves active bundle truth in| REGACTIVE
  SMENDPT -. pinned runtime serving surface .-> REGACTIVE
  REGACTIVE -->|read by| DF
  PROMO -->|stored in| EVID
  ROLLBACK -->|stored in| EVID
  SSM -->|provides handles to| DBX
  SSM -->|provides handles to| MLFLOW
  SSM -->|provides handles to| SM
  ROLEDBX -->|cross-account access for| DBX
  ROLESM -->|executes| SM

  classDef live fill:#e8f5e9,stroke:#2e7d32,color:#111,stroke-width:1.4px;
  classDef store fill:#e3f2fd,stroke:#1565c0,color:#111,stroke-width:1.4px;
  classDef managed fill:#fff3e0,stroke:#ef6c00,color:#111,stroke-width:1.4px;
  classDef retained fill:#f5f5f5,stroke:#616161,color:#111,stroke-dasharray: 5 3;
  class DF live;
  class ORACLE,OBJ,GLUEDB,EVID,SSM,TOFSREQ,TOFSEVT,TMFREQ,TMFEVT,TREG,TLABELS store;
  class DBX,SM,MLFLOW,DBXBUILD,DBXQUAL,SMPKG,ROLEDBX,ROLESM managed;
  class SMENDPT,REGACTIVE,PROMO,ROLLBACK retained;
