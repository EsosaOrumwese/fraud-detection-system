  end

  subgraph READYNOTE["Current Working Platform"]
    NOTE["Currently promoted working-platform core:<br>Control + Ingress + RTDL<br>Phase 0 closed green on 2026-03-10<br>Phase 1 closed green on 2026-03-11<br>Declared envelope: 3000 steady eps / 6000 burst eps"]
  end

  subgraph CONTROL["Control Network - Promoted Core"]
    GHA["GitHub Actions<br>bounded-run dispatch / workflow control"]
    SFN["Step Functions<br>platform-run orchestration"]
    CTRLBUS[["fp.bus.control.v1"]]
    RUNID["Run identity pins<br>platform_run_id / scenario_run_id<br>phase_id / trace_id / config_digest"]
    RUNCTL["Run control<br>receipts / reconciliation / proof story"]
  end

  subgraph INGRESS["Ingress Network - Promoted Core"]
    WSP["World Streamer Producer (WSP)<br>remote ECS/Fargate replay producer"]
    HTTPAPI["HTTP API Gateway<br>fraud-platform-dev-full-ig-edge<br>stage v1 / 3000 rps / 6000 burst"]
    IGLAMBDA["Ingress Lambda<br>fraud-platform-dev-full-ig-handler"]
    IGDDB[("DynamoDB idempotency ledger<br>fraud-platform-dev-full-ig-idempotency")]
    IGDLQ["SQS DLQ<br>fraud-platform-dev-full-ig-dlq"]
    TTRAFFIC[["fp.bus.traffic.fraud.v1"]]
  end

  subgraph RTDL["RTDL Network - Promoted Core"]
    RINTAKE["RTDL active intake set<br>arrival_events / arrival_entities / flow_anchor.fraud"]
    CSFB["CSFB<br>context_store_flow_binding"]
    IEG["IEG<br>identity_entity_graph"]
    OFP["OFP<br>online_feature_provider"]
    DF["DF<br>decision function"]
    DL["Decision Lane<br>decision publication"]
    DLA["Decision Ledger Append"]
    ARCH["Archive Writer"]
  end

  subgraph TRANSPORT["Promoted Event Transport Boundary"]
    MSK[("MSK Serverless<br>fraud-platform-dev-full-msk")]
    GLUEREG["Glue Schema Registry<br>fraud-platform-dev-full<br>BACKWARD"]
    TCTXA[["fp.bus.context.arrival_events.v1"]]
    TCTXE[["fp.bus.context.arrival_entities.v1"]]
    TFLOW[["fp.bus.context.flow_anchor.fraud.v1"]]
    TDEC[["RTDL decision / archive outputs"]]
  end

  subgraph SUPPORT["Supporting Trust / Evidence - Promoted Core"]
    OIDC["GitHub OIDC trust"]
    SSM["SSM Parameter Store<br>API key / brokers / active handles"]
    OBJ[("S3 object/oracle store<br>ingress replay basis")]
    EVID[("S3 evidence bucket<br>fraud-platform-dev-full-evidence")]
    CW["CloudWatch<br>APIGW / Lambda / WSP / RTDL logs + metrics"]
  end

  NOTE --> CONTROL
  NOTE --> INGRESS
  NOTE --> RTDL
  NOTE --> TRANSPORT

  GHA -->|authenticates through| OIDC
  GHA -->|dispatches| SFN
  SFN -->|assigns and persists| RUNID
  SFN -->|writes control receipts to| RUNCTL
  SFN -->|publishes orchestration signals to| CTRLBUS
  CTRLBUS -->|transported by| MSK
  SFN -->|starts bounded replay| WSP

  OBJ -->|provides replay basis to| WSP
  RUNID -->|pins active run scope for| WSP
  RUNID -->|pins active run scope for| IGLAMBDA
  RUNID -->|pins active run scope for| RTDL
  RUNID -->|pins active run scope for| RUNCTL

  WSP -->|pushes ingress load to| HTTPAPI
  HTTPAPI -->|invokes| IGLAMBDA
  IGLAMBDA -->|deduplicates in| IGDDB
  IGLAMBDA -->|writes failure disposition to| IGDLQ
  IGLAMBDA -->|publishes admitted traffic to| TTRAFFIC
  TTRAFFIC -->|transported by| MSK
  GLUEREG -. enforces schema compatibility for .-> TTRAFFIC

  TTRAFFIC -->|feeds promoted RTDL intake boundary| RINTAKE
  RINTAKE --> TCTXA
  RINTAKE --> TCTXE
  RINTAKE --> TFLOW
  TCTXA -->|consumed by| CSFB
  TCTXE -->|consumed by| CSFB
  TFLOW -->|consumed by| CSFB
  CSFB -->|binds context for| IEG
  IEG -->|supplies graph truth to| OFP
  OFP -->|supplies features to| DF
  DF -->|emits decisions to| DL
  DL -->|appends decision truth to| DLA
  DL -->|feeds archival evidence to| ARCH
  DL --> TDEC
  ARCH -->|stores evidence in| EVID
  DLA -->|stores proof continuity in| EVID
  RUNCTL -->|stores proof receipts in| EVID

  IGLAMBDA -->|reads active handles from| SSM
  WSP -->|reads active handles from| SSM
  RTDL -->|reads active handles from| SSM
  IGLAMBDA -->|emits logs and metrics to| CW
  WSP -->|emits logs to| CW
  RTDL -->|emits logs and metrics to| CW
  SFN -->|emits logs and metrics to| CW
  CW -. exposes operator visibility for .-> RUNCTL

  classDef note fill:#fff8e1,stroke:#f9a825,color:#111,stroke-width:1.3px;
  classDef control fill:#e8eaf6,stroke:#3949ab,color:#111,stroke-width:1.3px;
  classDef ingress fill:#f3e5f5,stroke:#6a1b9a,color:#111,stroke-width:1.3px;
  classDef rtdl fill:#e0f2f1,stroke:#00695c,color:#111,stroke-width:1.3px;
  classDef transport fill:#e3f2fd,stroke:#1565c0,color:#111,stroke-width:1.3px;
  classDef support fill:#f1f8e9,stroke:#558b2f,color:#111,stroke-width:1.3px;

  class NOTE note;
  class GHA,SFN,CTRLBUS,RUNID,RUNCTL control;
  class WSP,HTTPAPI,IGLAMBDA,IGDLQ,IGDDB,TTRAFFIC ingress;
  class RINTAKE,CSFB,IEG,OFP,DF,DL,DLA,ARCH rtdl;
  class MSK,GLUEREG,TCTXA,TCTXE,TFLOW,TDEC transport;
  class OIDC,SSM,OBJ,EVID,CW support;
