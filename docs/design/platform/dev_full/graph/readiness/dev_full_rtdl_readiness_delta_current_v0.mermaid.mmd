---
config:
  layout: dagre
  theme: default
---
flowchart LR

  subgraph LEGEND["How to Read This Graph"]
    L1["Left to right = component -> active blocker -> current impact -> readiness posture"]
    L2["Red = unresolved blocker"]
    L3["Amber = partly proven / not yet production-closed"]
    L4["Blue = measured or observed impact"]
    L5["Green = already proven"]
  end

  subgraph COMPONENTS["RTDL Components"]
    CSFB["Context Store Flow Binding (CSFB)"]
    IEG["Identity Entity Graph (IEG)"]
    OFP["Online Feature Plane (OFP)"]
    DL["Degrade Ladder (DL)"]
    DF["Decision Fabric (DF)"]
    AL["Action Layer (AL)"]
    DLA["Decision Log Audit (DLA)"]
    AW["Archive Writer"]
  end

  subgraph BLOCKERS["Active RTDL Blockers"]
    B1["OFP restart / recovery visibility not fully stable<br>fresh-run readiness can go dark after restart"]
    B2["DL can fail closed from stale or missing OFP dependency signals<br>false-red risk remains"]
    B3["DF fail-closed share is still too high for a healthy bounded run<br>semantic quality still not trusted"]
    B4["DLA lineage posture is not yet clean enough<br>unresolved lineage remains a real concern"]
  end

  subgraph IMPACT["Current Observed Impact"]
    M1["CSFB / IEG / OFP path is materially wired and has produced context and feature state<br>but restart and freshness trust still need closure"]
    M2["DL is functioning as a guardrail but not yet proven to distinguish true dependency loss from stale-health artifacts"]
    M3["DF produces decisions but not yet with an acceptably low false fail-closed share under bounded production-shaped pressure"]
    M4["AL and Archive Writer are materially participating<br>but full RTDL plane verdict stays blocked by OFP / DL / DF / DLA"]
    M5["RTDL is beyond wiring-only status<br>but not yet production-ready as an independent plane"]
  end

  subgraph VERDICT["Current RTDL Readiness"]
    V1["RTDL plane verdict<br>AMBER / RED<br>partly proven, not production-closed"]
    V2["What must happen next<br>stabilize OFP recovery semantics<br>clear false fail-closed behavior in DL/DF<br>clean DLA lineage posture<br>then rerun bounded RTDL proof"]
  end

  CSFB --> M1
  IEG --> M1
  OFP --> B1
  B1 --> M1
  DL --> B2
  B2 --> M2
  DF --> B3
  B3 --> M3
  AL --> M4
  DLA --> B4
  B4 --> M4
  AW --> M4
  M1 --> M5
  M2 --> M5
  M3 --> M5
  M4 --> M5
  M5 --> V1
  V1 --> V2

  classDef comp fill:#f3e5f5,stroke:#6a1b9a,color:#111,stroke-width:1.3px;
  classDef defect fill:#ffebee,stroke:#c62828,color:#111,stroke-width:1.3px;
  classDef metric fill:#e3f2fd,stroke:#1565c0,color:#111,stroke-width:1.3px;
  classDef warn fill:#fff3e0,stroke:#ef6c00,color:#111,stroke-width:1.3px;
  class CSFB,IEG,OFP,DL,DF,AL,DLA,AW comp;
  class B1,B2,B3,B4 defect;
  class M1,M2,M3,M4 metric;
  class M5,V1,V2 warn;
