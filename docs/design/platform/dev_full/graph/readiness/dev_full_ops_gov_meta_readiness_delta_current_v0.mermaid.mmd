---
config:
  layout: dagre
  theme: default
---
flowchart LR

  subgraph LEGEND["How to Read This Graph"]
    L1["Left to right = operational surface -> active concern -> current impact -> readiness posture"]
    L2["Red = unresolved blocker"]
    L3["Amber = present or partly exercised, not yet production-closed"]
    L4["Blue = observed or inferred current state"]
  end

  subgraph COMPONENTS["Ops / Gov / Meta Surfaces"]
    RC["Run control / receipts"]
    RP["Reporter / scorecard / rollup"]
    GOV["Governance append / immutable facts"]
    EVID["Evidence bucket / evidence paths"]
    OBS["Dashboards / metrics / alarms"]
    COST["Budget / cost guardrails / idle posture"]
    ID["Identity / handles / secrets / drift detection"]
  end

  subgraph BLOCKERS["Active Ops / Gov / Meta Blockers"]
    B1["These surfaces exist, but whole-platform reconstruction has not yet been proven across all active planes"]
    B2["Verdict traceability still depends on planes that are not yet production-closed"]
    B3["Cost, idle, drift, and evidence discipline are present but not yet fully certified as whole-platform operating controls"]
  end

  subgraph IMPACT["Current Observed Impact"]
    M1["Operational surfaces are materially present and have been used during proving work"]
    M2["They are not yet strong enough to certify the whole platform because the upstream planes remain amber/red"]
    M3["Ops / Gov / Meta is therefore partly proven but not yet production-closed as a plane"]
  end

  subgraph VERDICT["Current Ops / Gov / Meta Readiness"]
    V1["Ops / Gov / Meta verdict<br>AMBER / RED<br>present and partly exercised, not production-closed"]
    V2["What must happen next<br>prove exact run reconstruction, verdict traceability, drift detection, and cost-control once the upstream working network expands"]
  end

  RC --> B1
  RP --> B2
  GOV --> B1
  EVID --> B2
  OBS --> B3
  COST --> B3
  ID --> B3
  B1 --> M1
  B2 --> M2
  B3 --> M3
  M1 --> V1
  M2 --> V1
  M3 --> V1
  V1 --> V2

  classDef comp fill:#f3e5f5,stroke:#6a1b9a,color:#111,stroke-width:1.3px;
  classDef defect fill:#ffebee,stroke:#c62828,color:#111,stroke-width:1.3px;
  classDef metric fill:#e3f2fd,stroke:#1565c0,color:#111,stroke-width:1.3px;
  classDef warn fill:#fff3e0,stroke:#ef6c00,color:#111,stroke-width:1.3px;
  class RC,RP,GOV,EVID,OBS,COST,ID comp;
  class B1,B2,B3 defect;
  class M1,M2,M3 metric;
  class V1,V2 warn;
