    L3["Amber = accepted next execution posture"]
    L4["Blue = current evidence baseline"]
    L5["Green = promoted network state or later closure verdict"]
  end

  subgraph COUPLED["Phase 4 Coupled Scope"]
    C0["Promoted base entering Phase 4<br>Control + Ingress + RTDL + Case + Label"]
