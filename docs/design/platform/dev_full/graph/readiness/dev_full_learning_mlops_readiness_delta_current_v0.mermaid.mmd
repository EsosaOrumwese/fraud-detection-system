---
config:
  layout: dagre
  theme: default
---
flowchart LR

  subgraph LEGEND["How to Read This Graph"]
    L1["Left to right = managed surface -> active concern -> current impact -> readiness posture"]
    L2["Red = unresolved blocker"]
    L3["Amber = restored or partly proven, not yet production-closed"]
    L4["Blue = observed or inferred current state"]
  end

  subgraph COMPONENTS["Learning + Evolution / MLOps"]
    DBX["Databricks (Offline Feature Plane / OFS)"]
    SM["SageMaker (Model Factory / MF)"]
    MLF["MLflow (Model Promotion and Registry / MPR)"]
  end

  subgraph BLOCKERS["Active Learning / MLOps Blockers"]
    B1["Managed corridor is the correct runtime path, but end-to-end bounded proof is still incomplete"]
    B2["Dataset correctness, leakage safety, lineage completeness, and active-bundle resolution still need platform-grade validation"]
    B3["Learning cannot be promoted while upstream RTDL and Case + Label truth are not yet fully production-closed"]
  end

  subgraph IMPACT["Current Observed Impact"]
    M1["Managed surfaces are restored and represented as the intended learning corridor"]
    M2["The plane is beyond pure wiring, but not yet proven from runtime truth -> label truth -> dataset -> bundle -> active runtime"]
    M3["Current learning posture is structurally promising but operationally unconfirmed"]
  end

  subgraph VERDICT["Current Learning / MLOps Readiness"]
    V1["Learning + Evolution / MLOps verdict<br>AMBER / RED<br>managed corridor present, not production-closed"]
    V2["What must happen next<br>prove bounded dataset build, train/eval, promotion, rollback, and active-bundle resolution using authoritative upstream truth"]
  end

  DBX --> B1
  SM --> B2
  MLF --> B3
  B1 --> M1
  B2 --> M2
  B3 --> M3
  M1 --> V1
  M2 --> V1
  M3 --> V1
  V1 --> V2

  classDef comp fill:#f3e5f5,stroke:#6a1b9a,color:#111,stroke-width:1.3px;
  classDef defect fill:#ffebee,stroke:#c62828,color:#111,stroke-width:1.3px;
  classDef metric fill:#e3f2fd,stroke:#1565c0,color:#111,stroke-width:1.3px;
  classDef warn fill:#fff3e0,stroke:#ef6c00,color:#111,stroke-width:1.3px;
  class DBX,SM,MLF comp;
  class B1,B2,B3 defect;
  class M1,M2,M3 metric;
  class V1,V2 warn;
